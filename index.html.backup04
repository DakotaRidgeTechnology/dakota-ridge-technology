          <label>Last Name</label>
          <input type="text" placeholder="Smith">
        </div>
      </div>
      <div class="form-group">
        <label>Business Name</label>
        <input type="text" placeholder="Acme Co.">
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" placeholder="jane@acme.com">
      </div>
      <div class="form-group">
        <label>Service Interest <span style="color:var(--slate);font-size:0.58rem;letter-spacing:0.1em;">(select all that apply)</span></label>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.25rem;" id="service-checkboxes">
          <label class="svc-chip"><input type="checkbox" value="Microsoft 365 Management"> Microsoft 365</label>
          <label class="svc-chip"><input type="checkbox" value="Google Workspace"> Google Workspace</label>
          <label class="svc-chip"><input type="checkbox" value="Domain Management"> Domain Management</label>
          <label class="svc-chip"><input type="checkbox" value="Cloud Backup & Recovery"> Cloud Backup</label>
          <label class="svc-chip"><input type="checkbox" value="Endpoint Protection"> Endpoint Protection</label>
          <label class="svc-chip"><input type="checkbox" value="UniFi Wireless & Networking"> UniFi Networking</label>
          <label class="svc-chip"><input type="checkbox" value="Technical Support"> Technical Support</label>
          <label class="svc-chip"><input type="checkbox" value="General Inquiry"> General Inquiry</label>
        </div>
      </div>
      <div class="form-group">
        <label>Message</label>
        <textarea placeholder="Tell me a bit about your current setup and what you're looking to improve..."></textarea>
      </div>
      <button class="btn-primary" style="width:100%; text-align:center;" id="submit-btn" onclick="submitForm(event)">Send Message</button>
      <div id="form-status" style="display:none; font-family:'DM Mono',monospace; font-size:0.75rem; letter-spacing:0.1em; margin-top:1rem; text-align:center;"></div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <span class="footer-brand">Dakota Ridge Technology</span>
  <ul class="footer-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#why">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <span class="footer-copy">© 2025 Dakota Ridge Technology · Eastern South Dakota</span>
</footer>

<script>
  // Formspree form submission
  async function submitForm(e) {
    e.preventDefault();
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('submit-btn');
    const status = document.getElementById('form-status');
    const data = {
      firstName: form.querySelector('input[placeholder="Jane"]').value,
      lastName: form.querySelector('input[placeholder="Smith"]').value,
      business: form.querySelector('input[placeholder="Acme Co."]').value,
      email: form.querySelector('input[type="email"]').value,
      service: [...form.querySelectorAll('#service-checkboxes input:checked')].map(el => el.value).join(', ') || 'Not specified',
      message: form.querySelector('textarea').value,
    };
    if (!data.email || !data.message) {
      status.style.display = 'block';
      status.style.color = '#f0a500';
      status.textContent = 'Please fill in at least your email and message.';
      return;
    }
    btn.textContent = 'Sending...';
    btn.style.opacity = '0.7';
    btn.style.pointerEvents = 'none';
    try {
      const res = await fetch('https://formspree.io/f/mdayqjkg', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        status.style.display = 'block';
        status.style.color = '#00d4c8';
        status.textContent = 'Message sent! I\'ll be in touch soon.';
        btn.textContent = 'Sent ✓';
      } else {
        throw new Error();
      }
    } catch {
      status.style.display = 'block';
      status.style.color = '#f0a500';
      status.textContent = 'Something went wrong. Please email info@dakotaridgetechnology.com directly.';
      btn.textContent = 'Send Message';
      btn.style.opacity = '1';
      btn.style.pointerEvents = 'auto';
    }
  }

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));

  // Nav background intensify on scroll
  const nav = document.querySelector('nav');
  window.addEventListener('scroll', () => {
    nav.style.background = window.scrollY > 60
      ? 'rgba(13,17,23,0.97)'
      : 'rgba(13,17,23,0.85)';
  });
</script>
</body>
</html>
