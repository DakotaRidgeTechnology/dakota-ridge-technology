<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dakota Ridge Technology</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg viewBox='0 0 38 38' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='38' height='38' fill='%230d1117'/%3E%3Cpolygon points='2,30 12,10 19,22 26,10 36,30' stroke='%2300d4c8' stroke-width='2' fill='none' stroke-linejoin='round'/%3E%3Cpolygon points='8,30 19,14 30,30' fill='rgba(0,212,200,0.10)'/%3E%3Cline x1='2' y1='30' x2='36' y2='30' stroke='%2300d4c8' stroke-width='1.5' opacity='0.4'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0d1117;
    --ink-mid: #161c26;
    --ink-soft: #1e2736;
    --ridge: #243047;
    --cyan: #00d4c8;
    --cyan-dim: #00a89e;
    --cyan-glow: rgba(0, 212, 200, 0.12);
    --slate: #8899b0;
    --light: #c8d6e8;
    --white: #eef3f9;
    --gold: #f0a500;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--ink);
    color: var(--light);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 3rem;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(0, 212, 200, 0.08);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-mark {
    width: 38px;
    height: 38px;
    position: relative;
    flex-shrink: 0;
  }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .nav-wordmark .brand-top {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.05rem;
    letter-spacing: 0.18em;
    color: var(--white);
  }

  .nav-wordmark .brand-bot {
    font-family: 'DM Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.35em;
    color: var(--cyan);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--slate);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--cyan); }

  .nav-cta {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--cyan);
    border: none;
    padding: 0.6rem 1.4rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }

  .nav-cta:hover { background: #00ede0; transform: translateY(-1px); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding: 8rem 3rem 4rem;
    overflow: hidden;
  }

  /* Ridge silhouette background */
  .hero-ridge {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 55%;
    opacity: 0.12;
  }

  /* Grid lines */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,212,200,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,200,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 60% 40%, black 0%, transparent 70%);
  }

  /* Glow orb */
  .hero-glow {
    position: absolute;
    top: 15%;
    right: 10%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,212,200,0.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 780px;
  }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    animation: fadeUp 0.8s ease both;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: var(--cyan);
  }

  .hero-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 9vw, 8.5rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: var(--white);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.8s 0.1s ease both;
  }

  .hero-headline .accent { color: var(--cyan); }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--slate);
    max-width: 520px;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s 0.2s ease both;
  }

  .hero-actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    animation: fadeUp 0.8s 0.3s ease both;
  }

  .btn-primary {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--cyan);
    border: none;
    padding: 0.9rem 2rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s, transform 0.15s;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  }

  .btn-primary:hover { background: #00ede0; transform: translateY(-2px); }

  .btn-ghost {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cyan);
    background: transparent;
    border: 1px solid rgba(0,212,200,0.35);
    padding: 0.9rem 2rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--cyan);
    background: var(--cyan-glow);
  }

  /* ── STATS BAR ── */
  .stats-bar {
    position: relative;
    z-index: 2;
    background: var(--ink-mid);
    border-top: 1px solid rgba(0,212,200,0.1);
    border-bottom: 1px solid rgba(0,212,200,0.1);
    padding: 1.75rem 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    border-left: 1px solid rgba(0,212,200,0.15);
    padding-left: 1.5rem;
  }

  .stat-item:first-child { border-left: none; padding-left: 0; }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.2rem;
    color: var(--cyan);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate);
  }

  /* ── SECTION BASE ── */
  section {
    position: relative;
    z-index: 1;
    padding: 6rem 3rem;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-label::after {
    content: '';
    flex: 1;
    max-width: 60px;
    height: 1px;
    background: var(--cyan);
    opacity: 0.5;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    letter-spacing: 0.03em;
    color: var(--white);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    color: var(--slate);
    max-width: 520px;
    margin-bottom: 3.5rem;
  }

  /* ── SERVICES ── */
  #services { background: var(--ink); }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(0,212,200,0.08);
    border: 1px solid rgba(0,212,200,0.08);
  }

  .service-card {
    background: var(--ink-mid);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
    cursor: default;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--cyan);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .service-card:hover { background: var(--ink-soft); }
  .service-card:hover::before { transform: scaleX(1); }

  .service-icon {
    width: 44px;
    height: 44px;
    margin-bottom: 1.5rem;
    color: var(--cyan);
  }

  .service-num {
    position: absolute;
    top: 1.5rem;
    right: 1.75rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.5rem;
    color: rgba(0,212,200,0.06);
    line-height: 1;
    pointer-events: none;
  }

  .service-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.06em;
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .service-desc {
    font-size: 0.9rem;
    color: var(--slate);
    line-height: 1.65;
  }

  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.25rem;
  }

  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cyan-dim);
    border: 1px solid rgba(0,212,200,0.2);
    padding: 0.2rem 0.55rem;
  }

  /* ── WHY ── */
  #why {
    background: var(--ink-mid);
    overflow: hidden;
  }

  .why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .why-visual {
    position: relative;
    height: 420px;
  }

  .why-card {
    position: absolute;
    background: var(--ink-soft);
    border: 1px solid rgba(0,212,200,0.12);
    padding: 1.5rem;
  }

  .why-card-main {
    width: 75%;
    top: 0; left: 0;
    border-top: 2px solid var(--cyan);
  }

  .why-card-accent {
    width: 55%;
    bottom: 0; right: 0;
    border-top: 2px solid var(--gold);
  }

  .why-card-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate);
    margin-bottom: 0.75rem;
  }

  .why-card-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.8rem;
    color: var(--white);
    line-height: 1;
  }

  .why-card-value .unit {
    font-size: 1.2rem;
    color: var(--slate);
    margin-left: 0.25rem;
  }

  .why-card-sub {
    font-size: 0.82rem;
    color: var(--slate);
    margin-top: 0.4rem;
  }

  .why-card-accent .why-card-value { color: var(--gold); }

  .why-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .why-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .why-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--cyan);
    flex-shrink: 0;
    margin-top: 0.45rem;
    box-shadow: 0 0 10px var(--cyan);
  }

  .why-item-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    color: var(--white);
    margin-bottom: 0.25rem;
  }

  .why-item-desc {
    font-size: 0.88rem;
    color: var(--slate);
  }

  /* ── PROCESS ── */
  #process { background: var(--ink); }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  .process-steps::before {
    content: '';
    position: absolute;
    top: 1.75rem;
    left: 12.5%;
    right: 12.5%;
    height: 1px;
    background: linear-gradient(90deg, var(--cyan), rgba(0,212,200,0.1) 50%, var(--cyan));
    z-index: 0;
  }

  .process-step {
    padding: 0 2rem 2rem;
    position: relative;
    z-index: 1;
  }

  .step-dot {
    width: 3.5rem;
    height: 3.5rem;
    border: 1px solid rgba(0,212,200,0.3);
    background: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.75rem;
    position: relative;
  }

  .step-dot::after {
    content: '';
    position: absolute;
    inset: 4px;
    background: var(--cyan-glow);
  }

  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    color: var(--cyan);
    position: relative;
    z-index: 1;
  }

  .step-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 0.87rem;
    color: var(--slate);
    line-height: 1.6;
  }

  /* ── CONTACT ── */
  #contact {
    background: var(--ink-mid);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-detail {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-icon {
    width: 38px;
    height: 38px;
    border: 1px solid rgba(0,212,200,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--cyan);
  }

  .contact-detail-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate);
    margin-bottom: 0.2rem;
  }

  .contact-detail-value {
    color: var(--white);
    font-size: 0.95rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate);
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    background: var(--ink);
    border: 1px solid rgba(0,212,200,0.15);
    color: var(--white);
    padding: 0.8rem 1rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    border-color: var(--cyan);
  }

  .svc-chip {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--slate);
    border: 1px solid rgba(0,212,200,0.15);
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    user-select: none;
  }

  .svc-chip:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .svc-chip input[type="checkbox"] { display: none; }

  .svc-chip:has(input:checked) {
    border-color: var(--cyan);
    color: var(--ink);
    background: var(--cyan);
  }
  .form-group textarea { resize: vertical; min-height: 120px; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  /* ── FOOTER ── */
  footer {
    background: var(--ink);
    border-top: 1px solid rgba(0,212,200,0.08);
    padding: 2.5rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }

  .footer-brand {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    letter-spacing: 0.15em;
    color: var(--slate);
  }

  .footer-copy {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: rgba(136,153,176,0.5);
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .footer-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--slate);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--cyan); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── MOBILE ── */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    section { padding: 4rem 1.5rem; }
    .hero { padding: 7rem 1.5rem 3rem; }
    .stats-bar { grid-template-columns: 1fr 1fr; padding: 1.5rem; }
    .services-grid { grid-template-columns: 1fr; }
    .why-inner, .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .why-visual { height: 260px; }
    .process-steps { grid-template-columns: 1fr 1fr; }
    .process-steps::before { display: none; }
    .form-row { grid-template-columns: 1fr; }
    footer { flex-direction: column; gap: 1rem; text-align: center; }
    .footer-links { justify-content: center; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">
    <!-- SVG Logo Mark: Stylized ridge/chevron -->
    <svg class="logo-mark" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polygon points="2,30 12,10 19,22 26,10 36,30" stroke="#00d4c8" stroke-width="2" fill="none" stroke-linejoin="round"/>
      <polygon points="8,30 19,14 30,30" fill="rgba(0,212,200,0.10)"/>
      <line x1="2" y1="30" x2="36" y2="30" stroke="#00d4c8" stroke-width="1.5" opacity="0.4"/>
    </svg>
    <div class="nav-wordmark">
      <span class="brand-top">Dakota Ridge</span>
      <span class="brand-bot">Technology</span>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#why">About</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#contact" class="nav-cta">Get in Touch</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>

  <!-- Ridge SVG silhouette -->
